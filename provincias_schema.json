{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Listado de Provincias y CCAA",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "IDPovincia",
      "IDCCAA",
      "Provincia",
      "CCAA"
    ],
    "properties": {
      "IDPovincia": {
        "type": "string",
        "description": "Código identificador de la provincia."
      },
      "IDCCAA": {
        "type": "string",
        "description": "Código identificador de la Comunidad Autónoma."
      },
      "Provincia": {
        "type": "string",
        "description": "Nombre de la provincia."
      },
      "CCAA": {
        "type": "string",
        "description": "Nombre de la Comunidad Autónoma."
      }
    }
  }
}

